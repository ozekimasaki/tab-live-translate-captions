{
  "manifest_version": 3,
  "name": "Deepfram Live Translate Caption",
  "description": "Realtime translated caption overlay for any page using Deepgram and Gemini.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "offscreen",
    "scripting",
    "storage",
    "tabCapture"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.deepgram.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Deepfram",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "audio-worklet.js",
        "content.css",
        "content.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
